{
  "manifest_version": 3,
  "name": "KingKit Favourites",
  "version": "1.0.0",
  "description": "Save KingKit products for later with a one-click heart on every product image, then browse and manage them in one list.",
  "minimum_chrome_version": "102",
  "permissions": ["storage"],
  "host_permissions": ["*://*.kingkit.co.uk/*"],
  "action": {
    "default_title": "KingKit Favourites",
    "default_popup": "src/manager.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.kingkit.co.uk/*"],
      "js": ["src/storage.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
